# Copy this file to backend/.env and fill in real values.
# Never commit backend/.env.

# --- Database ---
# Postgres connection string (Neon, Supabase, RDS, local, etc.)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# --- Auth ---
# REQUIRED. Use a long random string. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# --- SMS provider (Text.lk) ---
TEXTLK_API_TOKEN=your-textlk-api-token
TEXTLK_SENDER_ID=TextLKDemo

# --- Server ---
PORT=5000

# Public URL the app is served from. Used in shop QR codes so they
# point to the right place locally vs in production.
#   PUBLIC_BASE_URL=http://localhost:5000
#   PUBLIC_BASE_URL=https://nestle-connect.onrender.com
PUBLIC_BASE_URL=http://localhost:5000

# When 'true', the redemption /start endpoint includes the OTP in the
# JSON response (so the demo store-verify.html page can show it).
# MUST be 'false' (or unset) in production.
DEMO_MODE=true
